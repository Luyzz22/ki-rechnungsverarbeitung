# =============================================================================
# SBS Deutschland – Invoice App: Beispiel-Umgebungskonfiguration
# Kopieren nach `.env` und Werte setzen. NIEMALS echte Secrets committen!
# =============================================================================

# --- Laufzeit / Umgebung -----------------------------------------------------
# development | staging | production  (development erlaubt unsichere Fallbacks)
ENVIRONMENT=production
APP_ENV=production
APP_BASE_URL=https://app.sbsdeutschland.com
APP_URL=https://app.sbsdeutschland.com
# Pfad für Anwendungs-Logs (muss beschreibbar sein)
APP_LOG_PATH=/var/www/invoice-app/logs/app.log

# --- Sicherheit / Sessions (PFLICHT in Produktion) ---------------------------
# Lange, zufällige Werte! z.B. `python -c "import secrets;print(secrets.token_urlsafe(48))"`
SECRET_KEY=change-me-please-very-long-random
SESSION_SECRET_KEY=change-me-please-very-long-random
JWT_SECRET=change-me-please-very-long-random

# --- Datenbank ---------------------------------------------------------------
# SQLite-Pfad (Standard: /var/www/invoice-app/invoices.db)
INVOICE_DB_PATH=/var/www/invoice-app/invoices.db
# Datei-Upload-Verzeichnis
UPLOAD_DIR=/var/www/invoice-app/web/uploads
# Standard-Mandant (Single-Tenant-Fallback)
DEFAULT_TENANT_ID=1

# --- KI / LLM (für Rechnungs-Extraktion) -------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# MBR (Monthly Business Review)
MBR_USE_LLM=0
MBR_LLM_API_KEY=
MBR_LLM_MODEL=gpt-4o

# --- E-Mail (Versand & Posteingang) ------------------------------------------
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=info@sbsdeutschland.com
# Alternativ SMTP:
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Posteingang (optionaler IMAP-Import)
IMAP_HOST=
IMAP_USER=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX
IMAP_PROCESSED_FOLDER=Processed

# --- SSO / OAuth (optional) --------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# --- Zahlungen / Stripe (optional) -------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_ENTERPRISE=

# --- API-Gateway / Integrationen (optional) ----------------------------------
INVOICE_API_KEY=
NEXUS_API_KEY=
SBS_API_KEY=
SLACK_WEBHOOK_URL=
CORS_ALLOWED_ORIGINS=https://app.sbsdeutschland.com

# --- Monitoring (optional) ---------------------------------------------------
SENTRY_DSN=
SENTRY_ENV=production
